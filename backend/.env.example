# --- Core ---
NODE_ENV=development
PORT=3000
# Public base URL of the API (used to build absolute upload URLs)
PUBLIC_BASE_URL=http://localhost:3000
# Comma-separated allowed CORS origins ("*" for dev)
CORS_ORIGINS=*
# Express trust-proxy setting: how many reverse proxies are in front (Caddy on the VPS => 1)
TRUST_PROXY=loopback

# --- Database ---
DATABASE_URL=postgresql://sarkis:sarkis_dev_password@localhost:5433/sarkis?schema=public
# Separate DB used by the e2e suite (created automatically)
DATABASE_URL_TEST=postgresql://sarkis:sarkis_dev_password@localhost:5433/sarkis_test?schema=public

# --- Auth ---
JWT_SECRET=change-me-long-random-string
JWT_ACCESS_TTL=900s
REFRESH_TTL_DAYS=30

# --- Superadmin bootstrap (created/updated by `npm run seed`) ---
SUPERADMIN_EMAIL=superadmin@sarkis.delivery
SUPERADMIN_PASSWORD=ChangeMe123!

# --- SMS / OTP ---
# dev = log the code & echo it in the API response (never use in production)
# gatewayapi = send real SMS through GatewayAPI (https://gatewayapi.com)
SMS_PROVIDER=dev
GATEWAYAPI_TOKEN=
GATEWAYAPI_SENDER=Sarkis

# --- Google Sign-In (web frontend; comma-separated OAuth client IDs) ---
GOOGLE_CLIENT_IDS=

# --- Push notifications (optional; path to a Firebase service-account JSON) ---
FIREBASE_SERVICE_ACCOUNT=
